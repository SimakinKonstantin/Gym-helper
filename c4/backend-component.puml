@startuml
!include <C4/C4_Component>

title Backend - Уровень Component

LAYOUT_LEFT_RIGHT()

Component(frontend, "Frontend", "Vue.js", "Пользовательский интерфейс приложения")

Container_Boundary(backend, "Backend") {
    Component(gateway, "Gateway", "Golang", "API Gateway, маршрутизация запросов и аутентификация")
    Component(authService, "Auth Service", "Golang", "Сервис аутентификации и авторизации")
    Component(managementService, "Management Service", "Golang", "Сервис управления программами и тренировками")
    Component(statisticsService, "Statistics Service", "Golang", "Сервис обработки и хранения статистики тренировок")

    ComponentDb(statisticsDb,  "БД сервиса статистики", "PostgreSQL", "Хранение статистики тренировок")
    ComponentDb(usersDb, "БД сервиса аутентификации", "PostgreSQL",  "Хранение пользователей")
    ComponentDb(managementDb, "БД сервиса тренировок", "PostgreSQL",  "Хранение тренировок")

    ComponentQueue(kafka, "Очередь на подтверждение программ тренировок", "Kafka", "Передает программу тренировок до пользователя для подтверждения")
}

' Component(statisticsDb,  "БД сервиса статистики", "PostgreSQL", "Хранение статистики тренировок")
' Component(usersDb, "БД сервиса аутентификации", "PostgreSQL",  "Хранение пользователей")
' Component(managementDb, "БД сервиса тренировок", "PostgreSQL",  "Хранение тренировок")

Rel(frontend, gateway, "Отправляет запросы", "HTTP")

Rel(gateway, authService, "Проксирование запросов аутентификации", "HTTP")
Rel(gateway, managementService, "Проксирование запросов управления", "HTTP")
Rel(gateway, statisticsService, "Проксирование запросов статистики", "HTTP")
Rel(gateway, kafka, "Отправка запроса на анализ тренировки", "TCP")
Rel(kafka, statisticsService, "Отправка запроса на анализ тренировки", "TCP")


Rel(authService, usersDb, "Хранение пользователей", "SQL")
Rel(managementService, managementDb, "Хранение программ и тренировок", "SQL")
Rel(statisticsService, statisticsDb, "Хранение статистики", "SQL")

SHOW_LEGEND()
@enduml

